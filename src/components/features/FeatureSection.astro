---
import { t, type Locale } from '../../i18n/utils';
import FeatureTabs from './FeatureTabs.tsx';
import ScrollReveal from '../ui/ScrollReveal.tsx';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
---

<section id="features" class="relative section-padding">
  <div class="glow-orb absolute top-0 left-0 h-[400px] w-[400px] bg-blue-500/[0.04]" />

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <ScrollReveal client:visible>
      <div class="text-center">
        <h2 class="font-display text-3xl font-bold text-white sm:text-4xl">
          {t('features.title', locale)}
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-text-secondary">
          {t('features.subtitle', locale)}
        </p>
      </div>
    </ScrollReveal>

    <div class="mt-12">
      <ScrollReveal client:visible>
        <FeatureTabs locale={locale} client:visible />
      </ScrollReveal>
    </div>
  </div>
</section>
