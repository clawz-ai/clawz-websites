---
import { t, type Locale } from '../../i18n/utils';
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import FeatureTabs from './FeatureTabs.tsx';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;

// Process feature screenshots to WebP
const allScreenshots = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/screenshots/feature-*.png',
  { eager: true },
);

const featureNames = [
  'feature-workshop',
  'feature-agents',
  'feature-models',
  'feature-channels',
  'feature-cost',
  'feature-logs',
];
const lang = locale === 'zh' ? 'zh' : 'en';

const processedImages = await Promise.all(
  featureNames.map((name) => {
    const key = `../../assets/screenshots/${name}-${lang}.png`;
    return getImage({ src: allScreenshots[key].default, width: 1280, format: 'webp', quality: 80 });
  }),
);
const screenshotUrls = processedImages.map((img) => img.src);
---

<section id="features" class="relative section-padding">
  <div class="glow-orb absolute top-0 left-0 h-[400px] w-[400px] bg-blue-500/[0.04]" />

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div data-reveal class="text-center">
      <h2 class="font-display text-3xl font-bold text-white sm:text-4xl">
        {t('features.title', locale)}
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-text-secondary">
        {t('features.subtitle', locale)}
      </p>
    </div>

    <div class="mt-12" data-reveal>
      <FeatureTabs locale={locale} screenshotUrls={screenshotUrls} client:visible />
    </div>
  </div>
</section>
