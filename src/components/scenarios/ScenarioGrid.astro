---
import { t, type Locale } from '../../i18n/utils';
import { scenarios } from '../../data/scenarios';
import ScenarioCard from './ScenarioCard.astro';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
---

<section id="scenarios" class="relative section-padding">
  <div class="glow-orb absolute top-1/2 right-0 h-[400px] w-[400px] -translate-y-1/2 bg-purple-500/[0.04]" />

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div data-reveal class="text-center">
      <h2 class="font-display text-3xl font-bold text-white sm:text-4xl">
        {t('scenarios.title', locale)}
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-text-secondary">
        {t('scenarios.subtitle', locale)}
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {scenarios.map((scenario, i) => (
        <div data-reveal data-reveal-delay={`${i * 0.08}s`}>
          <ScenarioCard
            emoji={scenario.emoji}
            nameKey={scenario.nameKey}
            descKey={scenario.descKey}
            tags={scenario.tags}
            tagsZh={scenario.tagsZh}
            locale={locale}
          />
        </div>
      ))}
    </div>
  </div>
</section>
