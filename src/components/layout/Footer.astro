---
import { t, type Locale } from '../../i18n/utils';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
---

<footer class="border-t border-border/50 bg-bg-base">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-4">
      <!-- Brand -->
      <div class="md:col-span-2">
        <div class="flex items-center gap-2.5">
          <img src="/logo-icon.png" alt="ClawZ" class="h-8 w-8" />
          <span class="text-lg font-bold text-white">ClawZ</span>
        </div>
        <p class="mt-3 text-sm text-text-secondary">
          {t('footer.tagline', locale)}
        </p>
        <p class="mt-4 text-xs text-text-muted">
          {t('footer.builtWith', locale)}
        </p>
      </div>

      <!-- Product -->
      <div>
        <h4 class="text-sm font-semibold text-white">{t('footer.product', locale)}</h4>
        <ul class="mt-3 space-y-2">
          <li><a href="#features" class="text-sm text-text-secondary transition-colors hover:text-white">{t('nav.features', locale)}</a></li>
          <li><a href="#scenarios" class="text-sm text-text-secondary transition-colors hover:text-white">{t('nav.scenarios', locale)}</a></li>
          <li><a href="#download" class="text-sm text-text-secondary transition-colors hover:text-white">{t('nav.download', locale)}</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="text-sm font-semibold text-white">{t('footer.resources', locale)}</h4>
        <ul class="mt-3 space-y-2">
          <li>
            <a href="https://github.com/clawz-ai/ClawZ" target="_blank" rel="noopener noreferrer" class="text-sm text-text-secondary transition-colors hover:text-white">
              GitHub
            </a>
          </li>
          <li><a href="https://github.com/clawz-ai/ClawZ#readme" target="_blank" rel="noopener noreferrer" class="text-sm text-text-secondary transition-colors hover:text-white">{t('footer.docs', locale)}</a></li>
          <li><a href="https://github.com/clawz-ai/ClawZ/releases" target="_blank" rel="noopener noreferrer" class="text-sm text-text-secondary transition-colors hover:text-white">{t('footer.changelog', locale)}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 border-t border-border/50 pt-6">
      <p class="text-center text-xs text-text-muted">
        &copy; {t('footer.copyright', locale)}
      </p>
    </div>
  </div>
</footer>
