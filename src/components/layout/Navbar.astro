---
import { t, type Locale, getAlternateUrl } from '../../i18n/utils';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const altLocale = locale === 'en' ? 'zh' : 'en';
const altUrl = locale === 'en' ? '/zh/' : '/';
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href={locale === 'zh' ? '/zh/' : '/'} class="flex items-center gap-2.5">
        <img src="/logo-icon.png" alt="ClawZ" class="h-8 w-8" />
        <span class="text-lg font-bold text-white">ClawZ</span>
      </a>

      <!-- Nav Links -->
      <div class="hidden items-center gap-8 md:flex">
        <a href="#features" class="text-sm text-text-secondary transition-colors hover:text-white">
          {t('nav.features', locale)}
        </a>
        <a href="#scenarios" class="text-sm text-text-secondary transition-colors hover:text-white">
          {t('nav.scenarios', locale)}
        </a>
        <a href="#download" class="text-sm text-text-secondary transition-colors hover:text-white">
          {t('nav.download', locale)}
        </a>
      </div>

      <!-- Right side -->
      <div class="flex items-center gap-3">
        <a href={altUrl} class="rounded-md px-2.5 py-1.5 text-xs font-medium text-text-secondary transition-colors hover:bg-bg-elevated hover:text-white">
          {altLocale === 'zh' ? '中文' : 'English'}
        </a>
        <a
          href="https://github.com/clawz-ai/ClawZ"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 rounded-lg border border-border bg-bg-surface/50 p-2 sm:px-3 sm:py-1.5 text-sm text-text-secondary transition-all hover:border-primary/50 hover:text-white"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          <span class="hidden sm:inline">GitHub</span>
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  let scrolled = false;

  function updateNavbar() {
    const shouldBeScrolled = window.scrollY > 20;
    if (shouldBeScrolled !== scrolled) {
      scrolled = shouldBeScrolled;
      if (scrolled) {
        navbar?.classList.add('bg-bg-base/80', 'backdrop-blur-xl', 'border-b', 'border-border/50');
      } else {
        navbar?.classList.remove('bg-bg-base/80', 'backdrop-blur-xl', 'border-b', 'border-border/50');
      }
    }
  }

  window.addEventListener('scroll', updateNavbar, { passive: true });
  updateNavbar();
</script>
