---
import { t, type Locale } from '../../i18n/utils';
import DownloadButton from '../hero/DownloadButton.tsx';
import ScrollReveal from '../ui/ScrollReveal.tsx';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
---

<section id="download" class="relative section-padding">
  <!-- Background glow -->
  <div class="glow-orb absolute top-1/2 left-1/2 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 bg-primary/[0.06]" />

  <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
    <ScrollReveal client:visible>
      <h2 class="font-display text-3xl font-bold text-white sm:text-4xl lg:text-5xl">
        {t('cta.title', locale)}
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-lg text-text-secondary">
        {t('cta.subtitle', locale)}
      </p>
      <div class="mt-10 flex justify-center">
        <DownloadButton locale={locale} client:load />
      </div>
    </ScrollReveal>
  </div>
</section>
