---
import { t, type Locale } from '../../i18n/utils';
import ScrollReveal from '../ui/ScrollReveal.tsx';
import { Download, Layers, Rocket } from 'lucide-react';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;

const steps = [
  { num: '1', icon: 'download', titleKey: 'steps.1.title' as const, descKey: 'steps.1.desc' as const, color: 'text-blue-400 bg-blue-500/15' },
  { num: '2', icon: 'layers', titleKey: 'steps.2.title' as const, descKey: 'steps.2.desc' as const, color: 'text-purple-400 bg-purple-500/15' },
  { num: '3', icon: 'rocket', titleKey: 'steps.3.title' as const, descKey: 'steps.3.desc' as const, color: 'text-green-400 bg-green-500/15' },
];
---

<section class="relative section-padding">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <ScrollReveal client:visible>
      <div class="text-center">
        <h2 class="font-display text-3xl font-bold text-white sm:text-4xl">
          {t('steps.title', locale)}
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-text-secondary">
          {t('steps.subtitle', locale)}
        </p>
      </div>
    </ScrollReveal>

    <div class="mt-16 grid grid-cols-1 gap-8 md:grid-cols-3">
      {steps.map((step, i) => (
        <ScrollReveal delay={i * 0.15} client:visible>
          <div class="relative text-center">
            {/* Connector line */}
            {i < 2 && (
              <div class="absolute top-10 left-[60%] hidden h-px w-[80%] bg-gradient-to-r from-border to-transparent md:block" />
            )}
            <div class={`mx-auto flex h-20 w-20 items-center justify-center rounded-2xl ${step.color}`}>
              {step.icon === 'download' && <Download className="h-8 w-8" />}
              {step.icon === 'layers' && <Layers className="h-8 w-8" />}
              {step.icon === 'rocket' && <Rocket className="h-8 w-8" />}
            </div>
            <div class="mt-1 text-xs font-bold text-text-muted">STEP {step.num}</div>
            <h3 class="mt-3 text-lg font-semibold text-white">
              {t(step.titleKey, locale)}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-text-secondary">
              {t(step.descKey, locale)}
            </p>
          </div>
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>
