---
import '../styles/global.css';
import { t, type Locale } from '../i18n/utils';
import { getImage } from 'astro:assets';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const title = t('meta.title', locale);
const description = t('meta.description', locale);
const canonicalPath = locale === 'en' ? '/' : '/zh/';
const canonicalUrl = `https://claw-z.com${canonicalPath}`;
const ogImage = `https://claw-z.com/screenshots/hero-dashboard-${locale}.png`;

// Preprocess hero image for LCP preload
import heroEn from '../assets/screenshots/hero-dashboard-en.png';
import heroZh from '../assets/screenshots/hero-dashboard-zh.png';
const heroImage = await getImage({
  src: locale === 'zh' ? heroZh : heroEn,
  width: 1920,
  format: 'webp',
  quality: 80,
});
---

<!doctype html>
<html lang={locale === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Canonical & hreflang -->
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href="https://claw-z.com/" />
    <link rel="alternate" hreflang="zh-CN" href="https://claw-z.com/zh/" />
    <link rel="alternate" hreflang="x-default" href="https://claw-z.com/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={locale === 'zh' ? 'zh_CN' : 'en_US'} />
    <meta property="og:site_name" content="ClawZ" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Preload hero image (LCP optimization) -->
    <link rel="preload" as="image" type="image/webp" href={heroImage.src} />

    <!-- Fonts (non-render-blocking) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
    </noscript>

    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-bg-base text-text-primary antialiased">
    <slot />

    <!-- Scroll reveal observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const el = entry.target as HTMLElement;
              const delay = el.dataset.revealDelay;
              if (delay) {
                el.style.transitionDelay = delay;
              }
              el.classList.add('revealed');
              observer.unobserve(el);
            }
          });
        },
        { rootMargin: '-60px' },
      );
      document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
